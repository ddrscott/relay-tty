{
  "name": "relay-tty",
  "version": "1.19.0",
  "description": "Terminal relay — run commands locally, access them from anywhere via browser",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ddrscott/relay-tty.git"
  },
  "homepage": "https://github.com/ddrscott/relay-tty",
  "keywords": [
    "terminal",
    "tty",
    "pty",
    "relay",
    "xterm",
    "websocket",
    "remote-terminal"
  ],
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "relay": "dist/cli/index.js",
    "relay-tty": "dist/cli/index.js"
  },
  "files": [
    "dist/",
    "build/",
    "scripts/",
    "server.js"
  ],
  "scripts": {
    "dev": "npm run build:rust; tsc -p tsconfig.node.json && node server.js",
    "build": "npm run build:rust; react-router build && tsc -p tsconfig.node.json",
    "start": "NODE_ENV=production node server.js",
    "start:tunnel": "npm run build && node dist/cli/index.js server start --tunnel",
    "build:cli": "tsc -p tsconfig.node.json",
    "build:rust": "command -v cargo >/dev/null 2>&1 && cargo build --release --manifest-path crates/pty-host/Cargo.toml || true",
    "prepack": "npm run build",
    "test": "tsc -p tsconfig.node.json && node --test dist/test/*.test.js",
    "postinstall": "node scripts/postinstall.js",
    "docs:dev": "cd docs && npm run dev",
    "docs:build": "cd docs && npm run build",
    "docs:screenshots": "./scripts/screenshots/run.sh"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.2",
    "@codemirror/lang-cpp": "^6.0.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-java": "^6.0.2",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-rust": "^6.0.2",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lang-yaml": "^6.1.2",
    "@codemirror/language": "^6.12.2",
    "@codemirror/state": "^6.5.4",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.39.17",
    "@react-router/express": "^7.12.0",
    "@react-router/node": "^7.12.0",
    "@tailwindcss/typography": "^0.5.19",
    "@xterm/addon-search": "^0.15.0",
    "@xterm/addon-unicode11": "^0.8.0",
    "@xterm/addon-webgl": "0.18.0",
    "@xterm/headless": "5.5.0",
    "commander": "^13.1.0",
    "compression": "^1.8.0",
    "cookie": "^1.0.0",
    "express": "^5.1.0",
    "isbot": "^5.1.0",
    "lucide-react": "^0.575.0",
    "marked": "^17.0.4",
    "morgan": "^1.10.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.12.0",
    "web-push": "^3.6.7",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@react-router/dev": "^7.12.0",
    "@tailwindcss/vite": "^4.1.0",
    "@types/compression": "^1.7.0",
    "@types/cookie": "^0.6.0",
    "@types/express": "^5.0.0",
    "@types/morgan": "^1.9.0",
    "@types/node": "^22.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.5.0",
    "@xterm/addon-fit": "0.10.0",
    "@xterm/addon-web-links": "0.11.0",
    "@xterm/xterm": "5.5.0",
    "daisyui": "^5.0.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.9.3",
    "vite": "^6.0.0",
    "vite-tsconfig-paths": "^4.3.0"
  }
}
